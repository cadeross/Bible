# Convex — https://dashboard.convex.dev (run `npx convex dev` to create a dev deployment)
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Clerk — https://dashboard.clerk.com → pick your app → API Keys
# All three values must be from the same Clerk application (switching apps = replace all three).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk Frontend API URL (JWT issuer). Copy from API Keys page (“Frontend API URL” / issuer), not the sign-in path.
# Example: https://stable-ray-31.clerk.accounts.dev (exact host shown in Dashboard)
CLERK_JWT_ISSUER_DOMAIN=https://your-app.clerk.accounts.dev

# Optional: used by SEO helpers
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Top-of-screen notice: database work in progress (unreliable accounts). Set to "true" to enable.
# NEXT_PUBLIC_DATABASE_MAINTENANCE_BANNER=true

# Bible API (unchanged)
# API_BIBLE_KEY=
